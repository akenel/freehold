# =============================================================
# Freehold — PRODUCTION box config  →  https://www.wolfhold.app
#   On the production server:  cp deploy/production.env.example .env
#   then replace every "change_me" with a STRONG, unique secret.
#   Deploy with `python3 ops/deploy.py production` — the backup gate runs first.
#
# SECRETS CHECKLIST — none of these may stay "change_me" in production:
#   [ ] POSTGRES_PASSWORD          [ ] KC_BOOTSTRAP_ADMIN_PASSWORD
#   [ ] KC_CLIENT_SECRET  (must also match the kc-prd client secret in Keycloak)
#   [ ] SESSION_SECRET  (long + random)   [ ] BACKUP_PASSPHRASE
#   [ ] MINIO_ROOT_PASSWORD
# Generate one with:  openssl rand -base64 36
#
# FIRST ADMIN: kc-prd ships with NO users. After launch, open the Keycloak admin
# console at https://auth.wolfhold.app/admin, register/find your account in the
# kc-prd realm, and grant it the 'admin' realm role. Self-serve sign-up is open;
# new users get no roles until you promote them.
# =============================================================

# --- Postgres ---
POSTGRES_USER=freehold
POSTGRES_PASSWORD=change_me_prod_strong
POSTGRES_APP_DB=freehold
POSTGRES_KC_DB=keycloak

# --- Keycloak bootstrap admin (the /admin console) ---
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=change_me_prod_strong

# --- Environment / realm (one shared Keycloak, three realms) ---
APP_ENV=production
KC_REALM=kc-prd

# --- This box's app front door (apex redirects to www at the proxy) ---
SITE_DOMAIN=www.wolfhold.app
APP_BASE_URL=https://www.wolfhold.app
APEX_DOMAIN=wolfhold.app       # bare wolfhold.app -> 301 to www (prod only)

# --- The shared Keycloak (auth.wolfhold.app) ---
AUTH_DOMAIN=auth.wolfhold.app
KC_PUBLIC_URL=https://auth.wolfhold.app
# Co-located on one box: keep the fast internal hop below.
# Separate auth box: set this to https://auth.wolfhold.app instead.
KC_INTERNAL_URL=http://keycloak:8080

# --- OIDC client (confidential — the server holds this secret) ---
KC_CLIENT_ID=freehold-web
KC_CLIENT_SECRET=change_me_prod_client_secret

# --- Session cookie (Secure because we're on real HTTPS) ---
SESSION_SECRET=change_me_prod_strong_session_key
SESSION_COOKIE_SECURE=true

# --- Backups (encrypted; used by ops/backup.py — gates the prod deploy) ---
BACKUP_PASSPHRASE=change_me_prod_strong_backup_key

# --- Email (SMTP) — default SMTP2GO (free: 1,000 mails/mo, custom sender domains).
# Any SMTP works. Create an SMTP user + verify a sender domain at the provider,
# then `make smtp` vaults the password and stamps host/user/from into the realms.
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_SSL=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@wolfhold.app
SMTP_FROM_NAME=Wolfhold


# --- Social logins (Keycloak identity providers) — see docs/SOCIAL-LOGIN.md ---
# Fill a provider's ID + SECRET, then `make idp` to enable it. Blank = off.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# --- MinIO (object storage: avatars, banners) ---
MINIO_ROOT_USER=freehold
MINIO_ROOT_PASSWORD=change_me_prod_minio
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=freehold

# --- Robot hardware bridge (sim now, a real Pi bridge later) ---
ROBOT_URL=http://robot-sim:9100
