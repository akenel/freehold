# =============================================================
# Freehold — SANDBOX box config  →  https://sandbox.wolfhold.app
#   On the sandbox server:  cp deploy/sandbox.env.example .env
#   then replace every "change_me" with a real, unique secret.
# =============================================================

# --- Postgres ---
POSTGRES_USER=freehold
POSTGRES_PASSWORD=change_me_sandbox
POSTGRES_APP_DB=freehold
POSTGRES_KC_DB=keycloak

# --- Keycloak bootstrap admin (the /admin console) ---
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=change_me_sandbox

# --- Environment / realm (one shared Keycloak, three realms) ---
APP_ENV=sandbox
KC_REALM=kc-sbx

# --- This box's app front door ---
SITE_DOMAIN=sandbox.wolfhold.app
APP_BASE_URL=https://sandbox.wolfhold.app

# --- The shared Keycloak (auth.wolfhold.app) ---
AUTH_DOMAIN=auth.wolfhold.app
KC_PUBLIC_URL=https://auth.wolfhold.app
# Co-located on one box: keep the fast internal hop below.
# Separate auth box: set this to https://auth.wolfhold.app instead.
KC_INTERNAL_URL=http://keycloak:8080

# --- OIDC client (confidential — the server holds this secret) ---
KC_CLIENT_ID=freehold-web
KC_CLIENT_SECRET=change_me_sandbox_client_secret

# --- Session cookie (Secure because we're on real HTTPS) ---
SESSION_SECRET=change_me_sandbox_session_key
SESSION_COOKIE_SECURE=true

# --- Backups (encrypted; used by ops/backup.py) ---
BACKUP_PASSPHRASE=change_me_sandbox_backup_key

# --- Email (SMTP) — default SMTP2GO (free: 1,000 mails/mo, custom sender domains).
# Any SMTP works. Create an SMTP user + verify a sender domain at the provider,
# then `make smtp` vaults the password and stamps host/user/from into the realms.
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_SSL=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@wolfhold.app
SMTP_FROM_NAME=Wolfhold


# --- Social logins (Keycloak identity providers) — see docs/SOCIAL-LOGIN.md ---
# Fill a provider's ID + SECRET, then `make idp` to enable it. Blank = off.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# --- MinIO (object storage: avatars, banners) ---
MINIO_ROOT_USER=freehold
MINIO_ROOT_PASSWORD=change_me_sandbox_minio
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=freehold

# --- Robot hardware bridge (sim now, a real Pi bridge later) ---
ROBOT_URL=http://robot-sim:9100
