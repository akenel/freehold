# =============================================================
# Freehold config — copy this to `.env` and change every "change_me".
#   cp .env.example .env
# .env is gitignored: your real secrets never get committed.
# =============================================================

# --- Postgres ---
POSTGRES_USER=freehold
POSTGRES_PASSWORD=change_me_dev_only
POSTGRES_APP_DB=freehold
POSTGRES_KC_DB=keycloak

# --- Keycloak bootstrap admin (the master admin console at /admin) ---
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=change_me_dev_only

# --- App: which environment/realm is this instance? ---
# One of: sandbox | staging | production. All three realms live in ONE shared
# Keycloak; each env picks its own:  sandbox=kc-sbx · staging=kc-stg · prod=kc-prd
APP_ENV=sandbox
KC_REALM=kc-sbx

# --- URLs ---
# Public base the BROWSER uses (the Caddy front door).
APP_BASE_URL=https://localhost:8443
# Where the BROWSER reaches Keycloak. Local/single-box: same host as the app.
# Shared-auth (wolfhold): the dedicated auth host, e.g. https://auth.wolfhold.app
KC_PUBLIC_URL=https://localhost:8443
# Internal URL the APP uses to reach Keycloak server-to-server. Co-located on one
# box: http://keycloak:8080. Separate auth box: https://auth.wolfhold.app
KC_INTERNAL_URL=http://keycloak:8080

# --- OIDC client (confidential — the server holds this secret) ---
KC_CLIENT_ID=freehold-web
KC_CLIENT_SECRET=freehold-dev-secret-change-me

# --- Session cookie signing key (make this long + random in prod) ---
SESSION_SECRET=change_me_dev_only_session_key
# Mark the session cookie Secure (HTTPS-only). Defaults to on whenever APP_BASE_URL
# is https (the norm, even in dev via Caddy). Set to false only for plain-http local runs.
SESSION_COOKIE_SECURE=true

# --- Backups (encrypted with openssl AES-256; used by ops/backup.py) ---
BACKUP_PASSPHRASE=change_me_dev_only_backup_key

# --- Email (Resend) — Keycloak sends forgot-password / verify mails via Resend ---
# One key for all realms (the same one you use for helixnet). After setting it,
# run `python3 ops/set-smtp.py` (or `make smtp`) to write it into Keycloak's vault,
# then restart Keycloak. The From address (no-reply@wolfhold.app) is set in the
# realm JSONs — verify the wolfhold.app domain in Resend so sends aren't rejected.
RESEND_API_KEY=change_me_resend_api_key

# --- Social logins (Keycloak identity providers) — see docs/SOCIAL-LOGIN.md ---
# Fill a provider's ID + SECRET, then `make idp` to enable it across all realms.
# Leave a provider blank to keep it off (no broken button). One OAuth app per
# provider with the three realm redirect URIs is simplest. IDs are public; the
# SECRETS go to Keycloak's vault (never committed).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# --- MinIO (object storage for images: avatars, banners) ---
MINIO_ROOT_USER=freehold
MINIO_ROOT_PASSWORD=change_me_dev_only_minio
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=freehold

# --- Robot hardware bridge (sim now, a real Pi bridge later) ---
ROBOT_URL=http://robot-sim:9100

# --- DuckDNS (only for the optional dynamic-IP updater; prod server .env) ---
# Get these from duckdns.org. The TOKEN is a SECRET — real value goes in .env
# (gitignored), NEVER in .env.example or git.
DUCKDNS_DOMAIN=freeholder
DUCKDNS_TOKEN=put-your-duckdns-token-in-.env-not-here
