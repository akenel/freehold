# =============================================================
# Freehold config — copy this to `.env` and change every "change_me".
#   cp .env.example .env
# .env is gitignored: your real secrets never get committed.
# =============================================================

# --- Postgres ---
POSTGRES_USER=freehold
POSTGRES_PASSWORD=change_me_dev_only
POSTGRES_APP_DB=freehold
POSTGRES_KC_DB=keycloak

# --- Keycloak bootstrap admin (the master admin console at /admin) ---
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=change_me_dev_only

# --- App: which environment/realm is this instance? ---
# One of: sandbox | staging | production  (realm = freehold-<env>)
APP_ENV=sandbox
KC_REALM=freehold-sandbox

# --- URLs ---
# Public base the BROWSER uses (the Caddy front door).
APP_BASE_URL=http://localhost:8080
KC_PUBLIC_URL=http://localhost:8080
# Internal URL the APP uses to reach Keycloak server-to-server.
KC_INTERNAL_URL=http://keycloak:8080

# --- OIDC client (confidential — the server holds this secret) ---
KC_CLIENT_ID=freehold-web
KC_CLIENT_SECRET=freehold-dev-secret-change-me

# --- Session cookie signing key (make this long + random in prod) ---
SESSION_SECRET=change_me_dev_only_session_key

# --- Backups (encrypted with openssl AES-256; used by ops/backup.py) ---
BACKUP_PASSPHRASE=change_me_dev_only_backup_key
