# Freehold ŌĆö one front door, HTTPS BY DEFAULT.
#
# Local dev uses Caddy's own internal CA (`tls internal`) on plain `localhost`,
# so there's no /etc/hosts editing and no mkcert install ŌĆö Caddy mints the cert
# itself. Run `make trust` once to trust that CA in your browser (then the green
# padlock, and secure-context features like camera + PWA + service workers work).
#
# In production you swap `localhost` for your real domain and delete `tls internal`
# ŌĆö Caddy fetches a real Let's Encrypt cert automatically. No config, no landlord.

localhost {
	tls internal

	# Keycloak: OIDC endpoints, its login theme resources, and the admin console
	handle /realms/* {
		reverse_proxy keycloak:8080
	}
	handle /resources/* {
		reverse_proxy keycloak:8080
	}
	handle /js/* {
		reverse_proxy keycloak:8080
	}
	handle /admin/* {
		reverse_proxy keycloak:8080
	}

	# Public media (avatars, banners) served from MinIO
	handle /media/* {
		uri strip_prefix /media
		reverse_proxy minio:9000
	}

	# The app (default)
	handle {
		reverse_proxy app:8000
	}
}
