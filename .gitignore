# python
__pycache__/
*.pyc
.venv/
# env / secrets — NEVER commit
.env
*.env
uat.env
# data
*.db
*.sqlite3
# local scratch
scratchpad/
# generated at deploy time
app/build-sha.txt
# encrypted db dumps (never commit backups)
backups/
# extracted local CA (generated by `make trust`)
freehold-local-ca.crt
# Keycloak file-vault secrets (SMTP password etc.) — written by ops/set-smtp.py
keycloak/vault/*
!keycloak/vault/.gitkeep
