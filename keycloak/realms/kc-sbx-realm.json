{
  "realm": "kc-sbx",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": true,
  "resetPasswordAllowed": true,
  "smtpServer": {
    "host": "smtp.resend.com",
    "port": "465",
    "ssl": "true",
    "starttls": "false",
    "auth": "true",
    "user": "resend",
    "password": "${vault.resendkey}",
    "from": "no-reply@wolfhold.app",
    "fromDisplayName": "Wolfhold"
  },
  "loginTheme": "freehold",
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Full access"
      },
      {
        "name": "staff",
        "description": "Everyday user"
      }
    ]
  },
  "clients": [
    {
      "clientId": "freehold-web",
      "name": "Freehold Web",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "freehold-dev-secret-change-me",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "redirectUris": [
        "https://localhost:8443/*",
        "https://sandbox.wolfhold.app/*"
      ],
      "webOrigins": [
        "https://localhost:8443",
        "https://sandbox.wolfhold.app"
      ],
      "attributes": {
        "post.logout.redirect.uris": "https://localhost:8443/*##https://sandbox.wolfhold.app/*"
      }
    }
  ],
  "users": [
    {
      "username": "demo",
      "enabled": true,
      "emailVerified": true,
      "email": "demo@freehold.local",
      "firstName": "Demo",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "demo",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin"
      ]
    },
    {
      "username": "sam",
      "enabled": true,
      "emailVerified": true,
      "email": "sam@freehold.local",
      "firstName": "Sam",
      "lastName": "Staff",
      "credentials": [
        {
          "type": "password",
          "value": "sam",
          "temporary": false
        }
      ],
      "realmRoles": [
        "staff"
      ]
    }
  ],
  "internationalizationEnabled": true,
  "supportedLocales": [
    "en",
    "hi"
  ],
  "defaultLocale": "en"
}
