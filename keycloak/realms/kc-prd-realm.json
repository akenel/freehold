{
  "realm": "kc-prd",
  "enabled": true,
  "displayName": "Wolfhold",
  "displayNameHtml": "Wolfhold",
  "sslRequired": "external",
  "registrationAllowed": true,
  "resetPasswordAllowed": true,
  "bruteForceProtected": true,
  "failureFactor": 10,
  "maxFailureWaitSeconds": 900,
  "permanentLockout": false,
  "smtpServer": {
    "host": "mail.smtp2go.com",
    "port": "587",
    "ssl": "false",
    "starttls": "true",
    "auth": "true",
    "user": "",
    "password": "${vault.smtppass}",
    "from": "no-reply@wolfhold.app",
    "fromDisplayName": "Wolfhold"
  },
  "loginTheme": "freehold",
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Full access"
      },
      {
        "name": "staff",
        "description": "Everyday user"
      }
    ]
  },
  "clients": [
    {
      "clientId": "freehold-web",
      "name": "Freehold Web",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "freehold-dev-secret-change-me",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "redirectUris": [
        "https://localhost:8443/*",
        "https://www.wolfhold.app/*",
        "https://wolfhold.app/*"
      ],
      "webOrigins": [
        "https://localhost:8443",
        "https://www.wolfhold.app",
        "https://wolfhold.app"
      ],
      "attributes": {
        "post.logout.redirect.uris": "https://localhost:8443/*##https://www.wolfhold.app/*##https://wolfhold.app/*"
      }
    }
  ],
  "identityProviders": [
    {
      "alias": "google",
      "providerId": "google",
      "enabled": false,
      "trustEmail": true,
      "storeToken": false,
      "linkOnly": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "",
        "clientSecret": "${vault.googlesecret}",
        "useJwksUrl": "true",
        "defaultScope": "openid profile email"
      }
    },
    {
      "alias": "github",
      "providerId": "github",
      "enabled": false,
      "trustEmail": false,
      "storeToken": false,
      "linkOnly": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "",
        "clientSecret": "${vault.githubsecret}",
        "defaultScope": "read:user user:email"
      }
    },
    {
      "alias": "facebook",
      "providerId": "facebook",
      "enabled": false,
      "trustEmail": false,
      "storeToken": false,
      "linkOnly": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "",
        "clientSecret": "${vault.facebooksecret}",
        "defaultScope": "email"
      }
    }
  ],
  "users": [],
  "internationalizationEnabled": true,
  "supportedLocales": [
    "en",
    "hi"
  ],
  "defaultLocale": "en"
}
